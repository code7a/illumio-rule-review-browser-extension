{
  "manifest_version": 3,
  "name": "illumio-rule-review",
  "version": "0.3.0",
  "permissions": ["webRequest", "webNavigation", "scripting", "storage"],
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
