{
  "manifest_version": 3,
  "name": "illumio-rule-review",
  "version": "0.6.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "click.serviceslab@illumio-rule-review-browser-extension",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["webRequest", "webNavigation", "scripting", "storage"],
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["https://*/*"],
  "background": {
    "scripts": ["background.js"]
  }
}
