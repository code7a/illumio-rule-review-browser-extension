{
  "manifest_version": 3,
  "name": "illumio-rule-review",
  "version": "0.5.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "illumio-rule-review@extension",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["webRequest", "webNavigation", "scripting", "storage"],
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": ["https://*/*"],
  "background": {
    "scripts": ["background.js"]
  }
}
